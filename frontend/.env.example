# Copy to `.env.local` and fill in values for your environment.
# All VITE_* vars are exposed to the client bundle — never put secrets here.

# ── Backend API ──────────────────────────────────────────────────────
# Base URL of the FastAPI server (no trailing slash).
VITE_API_URL=http://localhost:8000

# ── Supabase auth ────────────────────────────────────────────────────
# Required for real Google OAuth. Leave blank + set VITE_AUTH_BYPASS=true
# to develop without Supabase credentials.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Dev toggles ──────────────────────────────────────────────────────
# When true, "Continue with Google" resolves to a synthetic local user
# instead of hitting Supabase.
VITE_AUTH_BYPASS=false

# When true, the Phase 4 processing stage replays a scripted SSE-like
# timeline in the browser instead of hitting /api/pipeline/start +
# /api/jobs/{id}/stream. Useful for UI iteration.
VITE_MOCK_STREAM=false
